# ─── Admin Panel Authentication ─────────────────────────────────────────────
# Required. Password to access the admin panel at /admin
ADMIN_PASSWORD=your-strong-password-here

# ─── Lead & Feedback Capture ────────────────────────────────────────────────
# Optional. Google Apps Script webhook URL for capturing leads and feedback.
# If not set, lead/feedback capture is silently skipped (the app still works).
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# ─── Codebasics OAuth (Login with Codebasics) ───────────────────────────────
# Required if using "Login with Codebasics" OAuth authentication (Auth.js v5).
# Run `npx auth secret` to generate AUTH_SECRET.
# AUTH_SECRET=
# AUTH_CODEBASICS_CLIENT_ID=
# AUTH_CODEBASICS_CLIENT_SECRET=
# AUTH_CODEBASICS_ISSUER=https://codebasics.io

# ─── Optional ────────────────────────────────────────────────────────────────
# Enable strict plan validation (default: false).
# STRICT_VALIDATION=true
