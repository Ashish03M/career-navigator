# ─── Admin Panel Authentication ─────────────────────────────────────────────
# Required. Password to access the admin panel at /admin
ADMIN_PASSWORD=your-strong-password-here

# Optional. Separate HMAC key for session tokens. Falls back to ADMIN_PASSWORD if unset.
# Generate: openssl rand -base64 32
# AUTH_SECRET=

# ─── Google Sheets API (Lead & Feedback Capture) ────────────────────────────
# Optional. Service account credentials for writing leads/feedback to Google Sheets.
# If not set, lead/feedback capture is silently skipped (the app still works).
# 1. Create a service account in Google Cloud Console
# 2. Enable the Google Sheets API
# 3. Share your spreadsheet with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id

# ─── Sentry Error Tracking (Recommended) ─────────────────────────────────────
# Optional. Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN)
# If not set, Sentry is disabled and the app works normally without error tracking.
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o12345.ingest.sentry.io/12345
# Optional. Auth token for source map uploads (improves stack traces in Sentry dashboard)
# SENTRY_AUTH_TOKEN=

# ─── Microsoft Clarity Analytics (Optional) ──────────────────────────────────
# Optional. Get your project ID from https://clarity.microsoft.com → Setup
# If not set, no analytics script is loaded.
# NEXT_PUBLIC_CLARITY_ID=your-clarity-project-id

# ─── Optional ────────────────────────────────────────────────────────────────
# Enable strict plan validation (default: false).
# STRICT_VALIDATION=true
