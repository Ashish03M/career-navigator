{
    "name": "bootcamp-planner",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "postinstall": "node scripts/patch-next.js",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "test": "npx tsx scripts/validate-roadmap.ts",
        "test:verify": "npx tsx scripts/verify-all.ts",
        "test:matrix": "npx tsx scripts/test-matrix-hardened.ts",
        "test:schema": "npx tsx scripts/validate-schema.ts",
        "test:pdf": "npx tsx scripts/test-pdf-hardened.ts",
        "test:e2e": "npx playwright test",
        "typecheck": "npx tsc --noEmit",
        "verify": "npm run typecheck && npm run lint && npm run test && npm run test:verify",
        "verify:all": "npm run typecheck && npm run lint && npm run test && npm run test:verify && npm run test:matrix && npm run test:schema && npm run test:pdf"
    },
    "dependencies": {
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-label": "^2.1.8",
        "@radix-ui/react-scroll-area": "^1.2.10",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.8",
        "@radix-ui/react-tabs": "^1.1.13",
        "@react-pdf/renderer": "^4.3.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "framer-motion": "^12.0.0",
        "lucide-react": "^0.474.0",
        "next": "^14.2.29",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwind-merge": "^2.6.1",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/node": "20.19.33",
        "@types/react": "19.2.14",
        "@types/react-dom": "^19",
        "autoprefixer": "^10.4.19",
        "eslint": "^8",
        "eslint-config-next": "^14.2.29",
        "postcss": "^8",
        "tailwindcss": "^3.4.1",
        "typescript": "5.9.3"
    }
}
